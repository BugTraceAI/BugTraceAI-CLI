{
  "openapi": "3.0.0",
  "info": {
    "title": "Example API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "summary": "List users",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "example": 1
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" },
            "example": 10
          }
        ]
      },
      "post": {
        "summary": "Create user"
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Get user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "example": 123
          }
        ]
      },
      "put": {
        "summary": "Update user"
      },
      "delete": {
        "summary": "Delete user"
      }
    },
    "/products": {
      "get": {
        "summary": "List products",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/orders/{orderId}/items": {
      "get": {
        "summary": "Get order items",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login"
      }
    },
    "/search": {
      "get": {
        "summary": "Search",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" }
          }
        ]
      }
    }
  }
}
